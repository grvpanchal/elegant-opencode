{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "elegant-router",
  "compaction": { "auto": true, "prune": true, "reserved": 8192 },
  "provider": {
    "ollama": {
      "name": "Ollama (Local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": { "baseURL": "http://localhost:11434/v1" },
      "models": {
        "qwen3:32b-32k":   { "name": "Qwen3 32B (32k)",   "id": "qwen3:32b-32k",   "tool_call": true, "tools": true, "options": { "temperature": 0.05 }, "maxTokens": 8192 },
        "gemma3:27b-32k":  { "name": "Gemma3 27B (32k)",  "id": "gemma3:27b-32k",  "tool_call": true, "tools": true, "options": { "temperature": 0.05 }, "maxTokens": 8192 },
        "qwen3:14b-32k":   { "name": "Qwen3 14B (32k)",   "id": "qwen3:14b-32k",   "tool_call": true, "tools": true, "options": { "temperature": 0.0  }, "maxTokens": 4096 },
        "qwen3:8b-32k":    { "name": "Qwen3 8B (32k)",    "id": "qwen3:8b-32k",    "tool_call": true, "tools": true, "options": { "temperature": 0.0  }, "maxTokens": 2048 }
      }
    }
  },
  "agent": {
    "elegant-router":  { "mode": "primary",  "model": "ollama/qwen3:32b-32k",  "prompt": "./agents/elegant-router.md" },
    "schema-agent":    { "mode": "subagent", "model": "ollama/qwen3:8b-32k",   "prompt": "./agents/schema-agent.md",    "hidden": true },
    "selectors-agent": { "mode": "subagent", "model": "ollama/qwen3:8b-32k",   "prompt": "./agents/selectors-agent.md", "hidden": true },
    "atom-agent":      { "mode": "subagent", "model": "ollama/qwen3:14b-32k",  "prompt": "./agents/atom-agent.md",      "hidden": true },
    "molecule-agent":  { "mode": "subagent", "model": "ollama/qwen3:14b-32k",  "prompt": "./agents/molecule-agent.md",  "hidden": true },
    "organism-agent":  { "mode": "subagent", "model": "ollama/qwen3:32b-32k",  "prompt": "./agents/organism-agent.md",  "hidden": true },
    "container-agent": { "mode": "subagent", "model": "ollama/qwen3:14b-32k",  "prompt": "./agents/container-agent.md", "hidden": true }
  },
  "plugin": ["./src/index.js"]
}

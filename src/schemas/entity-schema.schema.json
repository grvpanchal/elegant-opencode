{
  "$id": "entity-schema.schema.json",
  "title": "Entity schema (pipeline seed)",
  "description": "Shape returned by the schema-agent. Becomes the entity input passed to every downstream microtask. The `kind` field selects the archetype pipeline; archetype-specific fields (e.g. operations for crud-list, queryField for fetch-card) are validated by anyOf.",
  "type": "object",
  "required": ["name", "slice", "kind"],
  "additionalProperties": true,
  "properties": {
    "name":          { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]+$" },
    "slice":         { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
    "appName":       { "type": "string" },
    "projectName":   { "type": "string" },
    "kind":          { "type": "string", "enum": ["crud-list", "fetch-card"] },
    "itemsField":    { "type": "string" },
    "currentField":  { "type": "string" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["create", "read", "edit", "update", "toggle", "delete"]
      }
    },
    "queryField":         { "type": "string" },
    "queryPlaceholder":   { "type": "string" },
    "responseFields": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "anyOf": [
    {
      "properties": { "kind": { "const": "crud-list" } },
      "required": ["operations"]
    },
    {
      "properties": { "kind": { "const": "fetch-card" } },
      "required": ["queryField", "responseFields"]
    }
  ]
}

{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "elegant-router",
  "compaction": { "auto": true, "prune": true, "reserved": 8192 },
  "agent": {
    "elegant-router":  { "mode": "primary",  "model": "opencode/big-pickle",            "prompt": "./agents/elegant-router.md" },
    "schema-agent":    { "mode": "subagent", "model": "opencode/gpt-5-nano",            "prompt": "./agents/schema-agent.md",    "hidden": true },
    "selectors-agent": { "mode": "subagent", "model": "opencode/gpt-5-nano",            "prompt": "./agents/selectors-agent.md", "hidden": true },
    "atom-agent":      { "mode": "subagent", "model": "opencode/nemotron-3-super-free", "prompt": "./agents/atom-agent.md",      "hidden": true },
    "molecule-agent":  { "mode": "subagent", "model": "opencode/minimax-m2.5-free",     "prompt": "./agents/molecule-agent.md",  "hidden": true },
    "organism-agent":  { "mode": "subagent", "model": "opencode/big-pickle",            "prompt": "./agents/organism-agent.md",  "hidden": true },
    "container-agent": { "mode": "subagent", "model": "opencode/hy3-preview-free",      "prompt": "./agents/container-agent.md", "hidden": true }
  },
  "plugin": ["./src/index.js"]
}

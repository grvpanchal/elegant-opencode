    "atomic-design",
    "redux",
    "ollama",
    "qwen3",
    "gemma3"
  ],
  "author": "Gaurav Panchal",
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "scripts": {
    "test": "node test/harness.test.js",
    "stability": "node test/stability.test.js",
    "demo:todo": "node scripts/run-todo-demo.js",
    "pages:build": "node scripts/build-pages.js"
  }
